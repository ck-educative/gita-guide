# ── LLM backend ──────────────────────────────────────────────
# auto   = Groq if GROQ_API_KEY set, else Ollama (recommended)
# groq   = always Groq Cloud
# ollama = always local Ollama
LLM_BACKEND=auto

# ── Groq (cloud) — free key at https://console.groq.com ──────
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# ── Ollama (local) — run: ollama pull llama3.2 ────────────────
OLLAMA_MODEL=gita-guide
OLLAMA_BASE_URL=http://localhost:11434

# ── Generation ────────────────────────────────────────────────
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=1024

# ── Vector store ──────────────────────────────────────────────
CHROMA_DB_PATH=./gita_db
RAG_K=4
CHUNK_SIZE=600
CHUNK_OVERLAP=80

# ── Data ──────────────────────────────────────────────────────
SOURCES_DIR=./sources
ANONYMIZED_TELEMETRY=False

# ── Vector store backend ─────────────────────────────────────
# auto   = use Qdrant if QDRANT_URL set, else ChromaDB (recommended)
# qdrant = always use Qdrant Cloud
# chroma = always use local ChromaDB
VECTOR_BACKEND=auto

# ── Qdrant vector store (cloud) ───────────────────────────────
# Get free at: https://cloud.qdrant.io
QDRANT_URL=https://xxx.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key
QDRANT_COLLECTION=gita_passages
